# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Frontend env (.env) — get these from Supabase dashboard:
# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# -----------------------------------------------------------------------------
# Backend secrets for Supabase Edge Functions
# Do NOT rely on local .env for deployed functions.
# Set these with: npx supabase secrets set KEY=value
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-project-id.supabase.co/functions/v1/gmail-oauth-callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send
GMAIL_OAUTH_STATE_SECRET=your-random-state-signing-secret
APP_URL=http://localhost:5173
